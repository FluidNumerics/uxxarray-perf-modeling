# Generated benchmark *data* -- regenerate with the make_*.py scripts. These can
# be large (10s of GB) and/or machine-specific (data/ is often a symlink to a
# scratch disk), so they are never committed.
**/data
**/data/
01_fio/fio_testfile.bin
*.nc
*.zarr

# NOTE: results/ (the measured benchmark outputs) ARE committed -- they are the
# evidence the READMEs reference.

__pycache__/
*.pyc
.ipynb_checkpoints/

# Large / regenerable profiling artifacts -- keep the text summaries (cprofile_top.txt),
# drop the multi-MB traces and binary profiles.
profiling/results/*.json
profiling/results/*.prof
profiling/results/*.svg

# pixi environments and lockfiles -- each stage has its own pixi.toml; envs are
# regenerated with `pixi install`. (Lockfiles omitted because Parcels is pulled
# from git and would otherwise pin a moving alpha.)
.pixi/
**/.pixi/
pixi.lock
**/pixi.lock
